# Duplicate this to a .env file and fill in with real values
# Do NOT commit a real .env — it is gitignored.

# Supabase
# The Postgres database in the cloud
# --- Do NOT put here ---
# - service_role / "secret" API key for the database (never in the browser; avoid in .env next to Vite unless you know you need it for admin scripts only)
# --- Supabase (browser-safe: OK for Vite) ---
# Used if you switch the frontend client to import.meta.env
VITE_SUPABASE_PROJECT_ID=<projectid>
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=https://<projectid>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
# --- Supabase (local scripts only, e.g. integration tests) ---
# Same URL/key as above; integration-testing.js loads these from .env via dotenv.
SUPABASE_URL=https://<projectid>.supabase.co
# Legacy name; value is the anon / publishable key (not the service_role secret).
SUPABASE_ANON_KEY=
# --- Supabase CLI (your machine only; optional if you use `supabase login`) ---
# Create at: https://supabase.com/dashboard/account/tokens
SUPABASE_DB_PASSWORD=
SUPABASE_ACCESS_TOKEN=

# Netlify
# The web host
NETLIFY_SITE_ID=
NETLIFY_AUTH_TOKEN=

# Exa Web Search
# The web search API for AI Agents Search and crawl with unmatched control, accuracy, and speed.
EXA_API_KEY=

# Browser Use
# The AI browser agent.
BROWSER_USE_API_KEY=

# Hyperbrowser
# Cloud browsers on-demand via API. Plug and play Puppeteer, Playwright, or Al agents and scale your scraping, testing, and automation without infrastructure headaches.
HYPERBROWSER_API_KEY=

# Browserbase
# We help AI use the web. Autonomously read, write, and perform tasks on the web with a serverless browser.
BROWSERBASE_PROJECT_ID=
BROWSERBASE_API_KEY=
GEMINI_API_KEY=

# Browserless
# Build reliable browser automation without fighting bots. Built for stealth, scale, and reliability. Run automations, scrape data, empower AI agents. Deploy headless browsers in Docker. Run on our cloud or bring your own. Free for non-commercial uses.
BROWSERLESS_API_KEY=

# ScraperAPI
# Collect data from any public website with our web scraping API, without worrying about proxies, browsers, or CAPTCHA handling.
SCRAPERAPI_API_KEY=

# Airtop
# Airtop is a cloud browser platform that allows you, your AI Agent, or your automation tools to control a web browser in the cloud. Airtop solves all browser automation problems by offering you a simple, scalable, and cost-effective service to run large numbers of browser sessions in the cloud and automate actions via natural language, all through a powerful, yet simple API.
AIRTOP_API_KEY=

# Oxylabs
# The Oxylabs MCP server provides a bridge between AI models and the web. It enables them to scrape any URL, render JavaScript-heavy pages, extract and format content for AI use, bypass anti-scraping measures, and access geo-restricted web data from 195+ countries.
OXYLABS_API_USERNAME=
OXYLABS_API_PASSWORD=
OXYLABS_API_KEY=

# ScrapingBee
# The Best Web Scraping API to Avoid Getting Blocked. The ScrapingBee web scraping API handles headless browsers, rotates proxies for you, and offers AI-powered data extraction.
SCRAPINGBEE_API_KEY=

# JigsawStack
# AI Web Scraper for dynamic websites. Scrape any website instantly and get consistent structured data in seconds without writing any css selector code.
JIGSAWSTACK_API_KEY=

# Firecrawl
# Turn websites into LLM-ready data. Power your AI apps with clean web data from any website. It's also open source.
FIRECRAWL_API_KEY=